<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

    ## TODO Looks like the app creates <style> element(s)) dynamically.
    ##  Investigate and check if this can be more strict by default.
    #set ($_cspStyleSrc = "style-src 'self' 'unsafe-inline' ${nonceScriptSrc}; style-src-elem 'self' 'unsafe-inline';")
    #parse("fragments/csp")

    <title></title>
    <script type="module" crossorigin src="$!_staticResourceRootPath/assets/js/api-driven-ui.js"></script>
    <link rel="stylesheet" crossorigin href="$!_staticResourceRootPath/assets/css/api-driven-ui.css">
</head>
<body>
<script $nonceAttr>
    window.__CONFIG__ = {
        initialUrl: '$_apiDrivenInitialUrl',
        haapi: {
            clientId: '$_apiDrivenClientInfo.clientId',
            tokenEndpoint: '$_apiDrivenClientInfo.tokenEndpoint',
        },
    };
</script>
<div id="root"></div>
</body>
</html>
